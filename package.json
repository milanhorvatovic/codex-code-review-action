  },
  "dependencies": {
    "@actions/artifact": "6.2.1",
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "description": "AI-powered code review GitHub Action using OpenAI Codex",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "24.14.1"
  },
  "homepage": "https://github.com/milanhorvatovic/codex-ai-code-review-action#readme",
  "license": "MIT",
  "name": "codex-ai-code-review-action",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/milanhorvatovic/codex-ai-code-review-action.git"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "extract:changelog": "tsx scripts/extract-changelog-section.ts",
    "lint": "eslint src/ scripts/",
    "prepare:release": "tsx scripts/prepare-release.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts",
    "verify:doc-pins": "tsx scripts/verify-doc-pins.ts",
    "verify:prose-style": "tsx scripts/verify-prose-style.ts"
  },
  "version": "2.0.0"
